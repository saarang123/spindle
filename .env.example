# Copy to .env and fill in. .env is gitignored.

# ─── deployment identity ────────────────────────────────────────────
# Logical node name this process runs on. Used for dispatcher binding,
# worker registration, and scheduler decisions. Arbitrary string.
SPINDLE_NODE=control

# ─── api ────────────────────────────────────────────────────────────
SPINDLE_API_BIND=0.0.0.0:8080
SPINDLE_API_URL=http://control.local:8080
SPINDLE_API_AUTH_TOKEN=

# ─── backend selection ──────────────────────────────────────────────
SPINDLE_STATE_BACKEND=mongo            # mongo | memory
SPINDLE_QUEUE_BACKEND=redis            # redis | memory
SPINDLE_ARTIFACT_BACKEND=local         # local | http

# ─── mongo ──────────────────────────────────────────────────────────
SPINDLE_MONGO_URL=mongodb://forge:CHANGE_ME@control.local:27017/spindle?authSource=admin
SPINDLE_MONGO_DB=spindle

# ─── redis ──────────────────────────────────────────────────────────
SPINDLE_REDIS_URL=redis://:CHANGE_ME@control.local:6379/0
SPINDLE_REDIS_QUEUE_PREFIX=spindle:queue
SPINDLE_REDIS_CONSUMER_GROUP=dispatchers

# ─── artifacts ──────────────────────────────────────────────────────
SPINDLE_ARTIFACT_BACKEND=s3            # local | s3
# local backend
SPINDLE_ARTIFACT_ROOT=/mnt/artifacts
SPINDLE_ARTIFACT_URI_SCHEME=file
# s3 backend (MinIO in dev, MinIO/S3/R2 in prod — same protocol)
SPINDLE_S3_ENDPOINT=http://localhost:9000           # http://<gpu-host>:9000 from another node
SPINDLE_S3_BUCKET=spindle-artifacts
SPINDLE_S3_ACCESS_KEY=                              # MINIO_ROOT_USER from infra/minio/.env
SPINDLE_S3_SECRET_KEY=                              # MINIO_ROOT_PASSWORD from infra/minio/.env
SPINDLE_S3_REGION=us-east-1                         # arbitrary; MinIO ignores

# ─── clickhouse (phase 8) ───────────────────────────────────────────
SPINDLE_CLICKHOUSE_URL=http://control.local:8123
SPINDLE_CLICKHOUSE_DB=spindle
SPINDLE_CLICKHOUSE_BUFFER_PATH=/var/lib/spindle/ch-buffer

# ─── dispatcher ─────────────────────────────────────────────────────
# Comma-separated list of model_config IDs this dispatcher will serve.
# Empty = serve all configs whose preferred_node matches SPINDLE_NODE.
SPINDLE_DISPATCHER_CONFIGS=
SPINDLE_DISPATCHER_TICK_MS=200
SPINDLE_DISPATCHER_LEASE_TTL_SECONDS=60
SPINDLE_DISPATCHER_HOST_CONCURRENCY=8

# ─── worker ─────────────────────────────────────────────────────────
SPINDLE_WORKER_ID=
SPINDLE_WORKER_CONFIG_ID=
SPINDLE_WORKER_IPC_SOCKET=/tmp/spindle-worker.sock
SPINDLE_WORKER_HEARTBEAT_SECONDS=10
SPINDLE_WORKER_CANCEL_POLL_SECONDS=2

# ─── logging ────────────────────────────────────────────────────────
SPINDLE_LOG_LEVEL=INFO
SPINDLE_LOG_FORMAT=json                # json | text
